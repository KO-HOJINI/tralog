# ==============================
# Tralog - 환경변수 설정 파일
# 이 파일을 .env 로 복사하여 실제 값을 채워 사용하세요.
# .env 파일은 절대 GitHub에 커밋하지 마세요! (.gitignore에 추가 필수)
# ==============================

# --- 백엔드 API 서버 주소 ---
# 개발 환경: http://localhost:5000
# 배포 환경: https://your-api-server.com
VITE_API_BASE_URL=http://localhost:5000

# --- 네이버 지도 API ---
# https://console.ncloud.com 에서 발급
# Application > 등록 > Web Dynamic Map 사용 설정
VITE_NAVER_MAP_CLIENT_ID=9ffc0uiggv
